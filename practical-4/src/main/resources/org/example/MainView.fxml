<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="700.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.controller.MainController">
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="50.0" style="-fx-background-color: #2c3e50;">
            <padding>
                <Insets left="20.0" />
            </padding>
            <Label text="Music Store Manager" textFill="WHITE">
                <font>
                    <Font name="System Bold" size="20.0" />
                </font>
            </Label>
        </HBox>
    </top>
    <center>
        <TabPane tabClosingPolicy="UNAVAILABLE">
            <!-- Employees Tab -->
            <Tab text="Employees">
                <VBox spacing="10.0">
                    <padding>
                        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                    </padding>
                    <HBox alignment="CENTER_LEFT" spacing="10.0">
                        <Label text="Search Employee:" />
                        <TextField fx:id="txtEmployeeFilter" promptText="Name or City..." prefWidth="250.0"/>
                    </HBox>
                    <TableView fx:id="tblEmployee" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colEmpFirstName" text="First Name" />
                            <TableColumn fx:id="colEmpLastName" text="Last Name" />
                            <TableColumn fx:id="colEmpTitle" text="Title" prefWidth="120.0" />
                            <TableColumn fx:id="colEmpCity" text="City" />
                            <TableColumn fx:id="colEmpCountry" text="Country" />
                            <TableColumn fx:id="colEmpPhone" text="Phone" prefWidth="120.0"/>
                            <TableColumn fx:id="colEmpReportsTo" text="Reports To" prefWidth="120.0"/>
                            <TableColumn fx:id="colEmpActive" text="Active" />
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                    </TableView>
                </VBox>
            </Tab>

            <!-- Tracks Tab -->
            <Tab text="Tracks">
                <VBox spacing="10.0">
                    <padding>
                        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                    </padding>
                    <HBox alignment="CENTER_LEFT" spacing="10.0">
                        <Button fx:id="btnAddTrack" text="+ Add New Track" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold;"/>
                    </HBox>
                    <TableView fx:id="tblTracks" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colTrackName" text="Track Name" prefWidth="200.0"/>
                            <TableColumn fx:id="colTrackAlbum" text="Album" prefWidth="150.0"/>
                            <TableColumn fx:id="colTrackGenre" text="Genre" />
                            <TableColumn fx:id="colTrackMediaType" text="Media Type" />
                            <TableColumn fx:id="colTrackComposer" text="Composer" prefWidth="150.0"/>
                            <TableColumn fx:id="colTrackUnitPrice" text="Unit Price" />
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                    </TableView>
                </VBox>
            </Tab>

            <!-- Report Tab -->
            <Tab fx:id="tabReport" text="Report">
                <VBox spacing="10.0">
                    <padding>
                        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                    </padding>
                    <Label text="Genre Revenue Report" style="-fx-font-size: 16px; -fx-font-weight: bold;" textFill="#2c3e50" />
                    <TableView fx:id="tblGenreRevenue" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colGenreName" text="Genre Name" />
                            <TableColumn fx:id="colGenreRevenue" text="Total Revenue ($)" />
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                    </TableView>
                </VBox>
            </Tab>

            <!-- Notifications / Customers Tab -->
            <Tab text="Notifications">
                <TabPane side="LEFT" tabClosingPolicy="UNAVAILABLE">
                    <Tab text="Customer CRUD">
                        <VBox spacing="15.0">
                            <padding>
                                <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                            </padding>
                            <GridPane hgap="15.0" vgap="15.0">
                                <Label text="First Name:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                                <TextField fx:id="txtCustFirstName" GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="200.0"/>
                                
                                <Label text="Last Name:" GridPane.columnIndex="2" GridPane.rowIndex="0" />
                                <TextField fx:id="txtCustLastName" GridPane.columnIndex="3" GridPane.rowIndex="0" prefWidth="200.0"/>
                                
                                <Label text="Email:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                                <TextField fx:id="txtCustEmail" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                                
                                <Label text="Phone:" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                                <TextField fx:id="txtCustPhone" GridPane.columnIndex="3" GridPane.rowIndex="1" />
                                
                                <Label text="Country:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                                <TextField fx:id="txtCustCountry" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                            </GridPane>
                            <HBox spacing="10.0">
                                <Button fx:id="btnCustCreate" text="Create" style="-fx-background-color: #2980b9; -fx-text-fill: white;" />
                                <Button fx:id="btnCustUpdate" text="Update" style="-fx-background-color: #f39c12; -fx-text-fill: white;" />
                                <Button fx:id="btnCustDelete" text="Delete" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" />
                                <Button fx:id="btnCustClear" text="Clear Form" />
                            </HBox>
                            <TableView fx:id="tblCustomers" VBox.vgrow="ALWAYS">
                                <columns>
                                    <TableColumn fx:id="colCustFirstName" text="First Name" />
                                    <TableColumn fx:id="colCustLastName" text="Last Name" />
                                    <TableColumn fx:id="colCustEmail" text="Email" prefWidth="200.0"/>
                                    <TableColumn fx:id="colCustPhone" text="Phone" />
                                    <TableColumn fx:id="colCustCountry" text="Country" />
                                </columns>
                                <columnResizePolicy>
                                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                </columnResizePolicy>
                            </TableView>
                        </VBox>
                    </Tab>
                    <Tab text="Inactive Customers">
                        <VBox spacing="10.0">
                            <padding>
                                <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                            </padding>
                            <HBox alignment="CENTER_LEFT" spacing="10.0">
                                <Label text="Search Inactive:" />
                                <TextField fx:id="txtInactiveCustFilter" promptText="Search by name..." prefWidth="250.0" />
                            </HBox>
                            <TableView fx:id="tblInactiveCustomers" VBox.vgrow="ALWAYS">
                                <columns>
                                    <TableColumn fx:id="colInactCustFirstName" text="First Name" />
                                    <TableColumn fx:id="colInactCustLastName" text="Last Name" />
                                    <TableColumn fx:id="colInactCustEmail" text="Email" prefWidth="200.0"/>
                                    <TableColumn fx:id="colInactCustPhone" text="Phone" />
                                </columns>
                                <columnResizePolicy>
                                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                </columnResizePolicy>
                            </TableView>
                        </VBox>
                    </Tab>
                </TabPane>
            </Tab>

            <!-- Customer Recommendations Tab -->
            <Tab text="Customer Recommendations">
                <VBox spacing="20.0">
                    <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                    </padding>
                    <HBox alignment="CENTER_LEFT" spacing="10.0">
                        <Label text="Select Customer:" style="-fx-font-size: 14px; -fx-font-weight: bold;" />
                        <ComboBox fx:id="cmbCustomerSelect" prefWidth="300.0" promptText="Choose Customer..." />
                    </HBox>
                    
                    <HBox spacing="20.0" VBox.vgrow="ALWAYS">
                        <!-- Left Side: Spending Summary & Favourite Genre -->
                        <VBox spacing="15.0" style="-fx-background-color: #f7f9fa; -fx-border-color: #bdc3c7; -fx-border-radius: 5; -fx-background-radius: 5;" prefWidth="350.0">
                            <padding>
                                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                            </padding>
                            <Label text="Spending Summary" style="-fx-font-size: 16px; -fx-font-weight: bold;" textFill="#2c3e50" />
                            <Separator />
                            <HBox spacing="10.0"><Label text="Total Spent:" style="-fx-font-weight: bold;"/><Label fx:id="lblTotalSpent" text="\$0.00" /></HBox>
                            <HBox spacing="10.0"><Label text="Total Purchases:" style="-fx-font-weight: bold;"/><Label fx:id="lblTotalPurchases" text="0" /></HBox>
                            <HBox spacing="10.0"><Label text="Most Recent Purchase:" style="-fx-font-weight: bold;"/><Label fx:id="lblRecentPurchase" text="N/A" /></HBox>
                            
                            <Label text="Favourite Genre Analysis" style="-fx-font-size: 16px; -fx-font-weight: bold;" textFill="#2c3e50">
                                <VBox.margin>
                                    <Insets top="15.0" />
                                </VBox.margin>
                            </Label>
                            <Separator />
                            <HBox spacing="10.0"><Label text="Favourite Genre:" style="-fx-font-weight: bold;"/><Label fx:id="lblFavGenre" text="None" /></HBox>
                        </VBox>
                        
                        <!-- Right Side: Track Recommendations -->
                        <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                            <Label text="Recommended Tracks" style="-fx-font-size: 16px; -fx-font-weight: bold;" textFill="#2c3e50" />
                            <TableView fx:id="tblRecommendations" VBox.vgrow="ALWAYS">
                                <columns>
                                    <TableColumn fx:id="colRecTrackName" text="Track Name" prefWidth="250.0"/>
                                    <TableColumn fx:id="colRecAlbum" text="Album" prefWidth="200.0"/>
                                    <TableColumn fx:id="colRecGenre" text="Genre" />
                                </columns>
                                <columnResizePolicy>
                                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                </columnResizePolicy>
                            </TableView>
                        </VBox>
                    </HBox>
                </VBox>
            </Tab>
        </TabPane>
    </center>
</BorderPane>